# GEMINI_API_KEY: Required for Gemini AI API calls.
# Automatically injects this at runtime from user secrets.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# Automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_REMOVE_BG_API_KEY: Required for remove.bg API calls.
VITE_REMOVE_BG_API_KEY=
